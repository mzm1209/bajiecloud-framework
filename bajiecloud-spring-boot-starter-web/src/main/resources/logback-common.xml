<?xml version="1.0" encoding="UTF-8"?>
<configuration>
     <!-- 使用springProperty读取Spring属性 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="system"/>
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>
    <!-- 定义公共的pattern字符串 -->
    <property name="COMMON_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId}] [traceId:%X{EagleEye-TraceID}] - [spanId:%X{span_id}] [${APP_NAME}] %logger{36} - %msg%n"/>
     <!-- 1. 专门用于 Feign Access 日志的 Appender，输出到独立文件 -->
    <appender name="FEIGN_ACCESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 你的 access 文件路径和名称 -->
        <file>${LOG_PATH}/${APP_NAME}-feign-access.log</file>
        <!-- 滚动策略：按日期和大小 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按日期和索引滚动 -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-feign-access.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 每个日志文件最大 100MB -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 保留最近30天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 所有日志文件总大小不超过 3GB -->
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <!-- 日志输出格式 -->
        <encoder>
            <pattern>${COMMON_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 2. 将名为 FEIGN_ACCESS 的 Logger 定向到上面的 Appender -->
    <logger name="FEIGN_ACCESS" level="INFO" additivity="false">
        <appender-ref ref="FEIGN_ACCESS_FILE"/>
    </logger>

    <!-- HTTP Access 日志的 Appender -->
    <appender name="HTTP_ACCESS_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-http-access.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按日期和索引滚动 -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-http-access.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 每个日志文件最大 100MB -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 保留最近30天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 所有日志文件总大小不超过 3GB -->
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${COMMON_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>


    <!-- 为 HTTP_ACCESS 日志名配置独立的 Appender -->
    <logger name="HTTP_ACCESS" level="INFO" additivity="false">
        <appender-ref ref="HTTP_ACCESS_FILE"/>
    </logger>


    <!-- 开发环境配置 -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
              <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) [%X{requestId}] [traceId:%X{EagleEye-TraceID}] - [spanId:%X{span_id}] [${APP_NAME}] %cyan(%logger{36}) - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
    
    <!-- 测试和生产环境配置 -->
    <springProfile name="prod | test">
       <appender name="APP_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
           <file>${LOG_PATH}/${APP_NAME}.log</file>
           <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
               <!-- 按日期和索引滚动 -->
               <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
               <!-- 每个日志文件最大 100MB -->
               <maxFileSize>100MB</maxFileSize>
               <!-- 保留最近30天的日志 -->
               <maxHistory>30</maxHistory>
               <!-- 所有日志文件总大小不超过 3GB -->
               <totalSizeCap>3GB</totalSizeCap>
           </rollingPolicy>
           <encoder>
               <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId}] ${APP_NAME} %logger{36} - %msg%n</pattern>
           </encoder>
       </appender>
      <!-- 3. 错误日志单独输出 -->
       <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
           <file>${LOG_PATH}/${APP_NAME}-error.log</file>
           <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
               <level>ERROR</level>
           </filter>
           <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
               <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
               <maxFileSize>100MB</maxFileSize>
               <maxHistory>90</maxHistory> <!-- 错误日志保留更久 -->
           </rollingPolicy>
           <encoder>
               <pattern>${COMMON_PATTERN}</pattern>
               <charset>UTF-8</charset>
           </encoder>
       </appender>

        <root level="INFO">
             <appender-ref ref="APP_LOG"/>
             <appender-ref ref="ERROR_FILE"/>
         </root>
    </springProfile>
</configuration>
