# 系统服务名，必填，如 system-service
spring.application.name=
=================MSE Nacos 配置信息=========================
# MSE Nacos 服务器地址，用于连接 MSE Nacos 配置中心和服务发现，必填
MSE_NACOS_SERVER_ADDR=

# Nacos 命名空间，用于隔离不同环境或项目的配置，必填
NACOS_NAMESPACE=

# Nacos 组名，用于对配置进行分组管理，默认为 DEFAULT_GROUP
NACOS_GROUP=DEFAULT_GROUP

# Nacos 用户名，用于开启鉴权时的身份验证
NACOS_USERNAME=

# Nacos 密码，与用户名配合使用进行身份验证
NACOS_PASSWORD=

# 阿里云访问密钥 ID，用于阿里云服务鉴权
ALIBABA_CLOUD_ACCESS_KEY=

# 阿里云访问密钥 Secret，用于阿里云服务鉴权
ALIBABA_CLOUD_SECRET_KEY=

# Nacos 集群端点，用于指定集群模式下的端点地址
NACOS_ENDPOINT=

# Nacos 上下文路径，当 Nacos 部署在特定上下文路径时使用，默认为 /nacos
NACOS_CONTEXT_PATH=/nacos

# Nacos 编码格式，指定配置读取时使用的字符编码，默认为 UTF-8
NACOS_ENCODE=UTF-8

# Nacos 服务发现集群名称，用于区分不同的运行环境，默认为 DEFAULT
NACOS_CLUSTER_NAME=DEFAULT

# Nacos 服务发现注册 IP，指定服务注册时使用的 IP 地址
NACOS_DISCOVERY_IP=

# Nacos 服务发现临时实例标识，决定是否注册为临时实例，默认为 true
NACOS_DISCOVERY_EPHEMERAL=true

# Nacos 心跳间隔时间，单位毫秒，默认为 5000 毫秒
NACOS_HEART_BEAT_INTERVAL=5000

# Nacos 心跳超时时间，单位毫秒，默认为 15000 毫秒
NACOS_HEART_BEAT_TIMEOUT=15000

# Nacos IP 删除超时时间，单位毫秒，默认为 30000 毫秒
NACOS_IP_DELETE_TIMEOUT=30000

# Nacos 服务实例权重，范围 1-100，默认为 1.0
NACOS_DISCOVERY_WEIGHT=1.0

# Nacos 服务发现启用开关，控制是否启用服务发现功能，默认为 true
NACOS_DISCOVERY_ENABLED=true

# Nacos 注册启用开关，控制是否允许服务注册，默认为 true
NACOS_REGISTER_ENABLED=true

# Nacos 服务发现日志名称，指定服务发现的日志文件名
NACOS_DISCOVERY_LOG_NAME=mse-discovery-log

# Nacos 服务发现安全传输开关，控制是否启用 HTTPS 安全传输，默认为 false
NACOS_DISCOVERY_SECURE=false
